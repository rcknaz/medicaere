{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Medical professional profile",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "department": { "type": "string" },
        "experience": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "availability": { "type": "array" },
        "schedule": { "type": "object" }
      }
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Medical appointment booking",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "reason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Report": {
      "title": "Report",
      "description": "Patient medical report",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profile data"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Public doctor profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "All hospital appointments"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Secure medical reports"
    }
  }
}
